      "source": [
        "simple tokenizer just encode decode and take inputs and do the work"
      ],
      "metadata": {
        "id": "T7tYPkMgRD82"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "  class simpletokenizerv1 :\n",
        "    def __init__(self,vocab): # a kind of cunstructor\n",
        "    #self is imp for the function ye jo bhi varible uske pas hota hai o pure function and other function ko bhi chipka sakta hai\n",
        "    # __ aaisa kisi fun aage pich ho then that is special function\n",
        "    #\n",
        "      self.str_to_int = vocab #ye ek nyi dictionery build kr raha hai str_to_int jo self me save hogi\n",
        "      self.int_to_str = {i: s for s,i in vocab.items()}\n",
        "      # items ek dictionery ka built in function hai\n",
        "      # ye ab dictionery read karege hamare liye\n",
        "      # strings and number ko read karne k liye use hota hai\n",
        "      #\"s\" string \"i\" integers --> inbuild hai\n",
        "      #       self.int_to_str = {i: s for s,i in vocab.items()}\n",
        "         # isks matlab hai ki flip kro now dictionery me number pahaile then string\n",
        "         # eg {0: \"apple\", 1: \"banana\"}\n",
        "    def encode (self,text): #text sample text hai jo user dene wala hai\n",
        "    #encoding string to int\n",
        "#preprocessed kr variable hai bs jo ab us sample text k liye kam karega\n",
        "     preprocessed = re.split(r'([!@#$%<>,.?/()\"\\'|{}]|-|--|\\s)',text)\n",
        "     preprocessed = [item.strip() for item in preprocessed if item and item.strip()]\n",
        "     ids = [self.str_to_int[s] for s in preprocessed] # isa matlab hai ki\n",
        "     # \"s\" ek single string hai preprocessed variable list ki (jo user give hai )\n",
        "     #iska kahana hai ki user ne diya hua ek ek word uthao usko str_to_int me dalo\n",
        "     #and uski id \"ids\" variable me save kro\n",
        "     return ids\n",
        "     # ab verdict and user text kaha connected hai ? - yaha self.str_to_text\n",
        "\n",
        "    def decode(self,ids ):\n",
        "      text = \" \".join([self.int_to_str[i] for i in ids ])\n",
        "      # add space after each id (string)end\n",
        "      # but ye , . ke pahaile bhi ek space add karega eg:- hello , i\n",
        "      text = re.sub(r'\\s+([,.?!\"()\\'])', r'\\1', text)\n",
        "      #resub ek cleaner hai ki space k bad ager koi [] symbol hoga to usko space my do\n",
        "      return text\n",
        "\n"
      ],
      "metadata": {
        "id": "iBWmIuI77yel"
      },
