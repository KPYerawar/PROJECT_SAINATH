    {
      "cell_type": "markdown",
      "source": [
        "  ** **IMPLEMENTING A DATA LOADER**"
      ],
      "metadata": {
        "id": "HwiSw5lQHQpX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from torch.utils.data import Dataset, DataLoader\n",
        "import torch\n",
        "\n",
        "# Dataset: Yeh ek \"Almari\" hai jahan aapne saare data (text) ko chhote-chhote x aur y ke tukdon mein kaat kar sahi\n",
        "# tareeke se saja kar rakha hai.\n",
        "\n",
        "# DataLoader: Yeh ek \"Delivery Boy\" hai jo us almari se tukde uthata hai, unka \"Batch\" (group) banata hai,\n",
        "# aur AI model ko khane (training) ke liye bhejta hai.\n",
        "\n",
        "class GPTDatasetV1(Dataset):\n",
        "  # we are providing already made dataset\n",
        "  def __init__(self, txt, tokenizer, max_length, stride): # setup function\n",
        "    self.input_ids = []\n",
        "    self.target_ids = []\n",
        "    # this are empty list for x and y\n",
        "\n",
        "    # now token the entire user given text\n",
        "    token_ids = tokenizer.encode(txt, allowed_special={\"<|endoftext|>\"})\n",
        "    # book strings to tokens id (encoding)\n",
        "\n",
        "    # sliding window\n",
        "    for i in range(0, len(token_ids) - max_length, stride):\n",
        "      input_chunk = token_ids[i:i + max_length] # no of id in chunk\n",
        "      target_chunk = token_ids[i + 1 : i + max_length + 1] # taget chunk\n",
        "      self.input_ids.append(torch.tensor(input_chunk))\n",
        "      self.target_ids.append(torch.tensor(target_chunk))\n",
        "      # unko tensor me convert karta hai taki pytorch isko pd sakhe\n",
        "\n",
        "  # --- ERROR FIX: Ye dono functions 'class' ke andar (4 spaces aage) hone chahiye ---\n",
        "  def __len__(self):\n",
        "    return len(self.input_ids)\n",
        "\n",
        "  def __getitem__(self, idx):\n",
        "    return self.input_ids[idx], self.target_ids[idx]"
      ],
      "metadata": {
        "id": "ayV9JUd6HQDm"
      },
      "execution_count": 134,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Example Scenario:\n",
        "Maan lo aapne 1000 words ki story di.\n",
        "max_length=4 aur stride=4 rakha.\n",
        "\n",
        "__init__ us story ke 250 tukde (1000/4) bana dega.\n",
        "\n",
        "__len__ hamesha 250 batayega.\n",
        "\n",
        "__getitem__(0) aapko pehle 4 words aur unka target de dega."
      ],
      "metadata": {
        "id": "pSqmBgCuO5hj"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "ab hmne dataset banaya x and y me usko tod diya\n",
        "ab dataloader ko bulaker uski dilevery bhi kr denge\n",
        "ye bs puchta hai user inputs"
      ],
      "metadata": {
        "id": "gYcUKBlCPQY6"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def create_dataloader_v1(txt, batch_size=4, max_length=256,\n",
        "                         stride=128, shuffle=True, drop_last=True,\n",
        "                         num_workers=0):\n",
        "\n",
        "    # Initialize the tokenizer\n",
        "    tokenizer = tiktoken.get_encoding(\"gpt2\")\n",
        "\n",
        "    # Create dataset\n",
        "    dataset = GPTDatasetV1(txt, tokenizer, max_length, stride)\n",
        "\n",
        "    # Create dataloader\n",
        "    dataloader = DataLoader(\n",
        "        dataset,\n",
        "        batch_size=batch_size,\n",
        "        shuffle=shuffle,\n",
        "        drop_last=drop_last,\n",
        "        num_workers=num_workers\n",
        "    )\n",
        "\n",
        "    return dataloader"
      ],
      "metadata": {
        "id": "SZuc_g7nNGA1"
      },
      "execution_count": 126,
      "outputs": []
    },
